[
  "run",
  "--name",
  "$ID",
  "--label",
  "dev.gascan.managed-by=gascan",
  "--label",
  "dev.gascan.sandbox-id=$ID",
  "--mount",
  "type=bind,source=$ROOT,target=/workspace",
  "--volume",
  "gascan-mise-$ID:/home/workspace/.local/share/mise",
  "--volume",
  "gascan-cache-$ID:/home/workspace/.cache",
  "--volume",
  "gascan-config-$ID:/home/workspace/.config/gascan",
  "--cpus",
  "4",
  "--memory",
  "8589934592",
  "--init",
  "--detach",
  "--network",
  "none",
  "$IMAGE"
]
