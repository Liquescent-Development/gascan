[
  "run",
  "--name",
  "$ID",
  "--label",
  "dev.gascan.managed-by=gascan",
  "--label",
  "dev.gascan.sandbox-id=$ID",
  "--mount",
  "type=bind,source=$ROOT,target=/workspace",
  "--volume",
  "gascan-mise-$ID:/home/workspace/.local/share/mise",
  "--volume",
  "gascan-cache-$ID:/home/workspace/.cache",
  "--volume",
  "gascan-config-$ID:/home/workspace/.config/gascan",
  "--env",
  "HOME=/home/workspace",
  "--env",
  "MISE_CACHE_DIR=/home/workspace/.cache/mise",
  "--env",
  "MISE_DATA_DIR=/home/workspace/.local/share/mise",
  "--env",
  "MISE_GLOBAL_CONFIG_FILE=/home/workspace/.config/gascan/mise.toml",
  "--env",
  "PATH=/home/workspace/.local/share/mise/shims:/opt/gascan/mise/shims:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
  "--cpus",
  "4",
  "--memory",
  "8589934592",
  "--init",
  "--detach",
  "--network",
  "none",
  "$IMAGE"
]
